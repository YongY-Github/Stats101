# Generate 10,000 random samples from N(0,1)
samples <- rnorm(10000, mean = 0, sd = 1)
# Plot histogram
hist(samples, breaks = 50, probability = TRUE,
col = "lightgray", border = "white",
main = "Histogram with Gaussian Curve")
# Overlay the theoretical curve
curve(dnorm(x, mean = 0, sd = 1),
col = "red", lwd = 2, add = TRUE)
# install.packages("ggplot2")
library(ggplot2)
# Create data
x <- seq(-4, 4, length.out = 100)
y <- dnorm(x, mean = 0, sd = 1)
df <- data.frame(x, y)
# Plot with ggplot2
ggplot(df, aes(x, y)) +
geom_line(color = "darkblue", size = 1.2) +
labs(title = "Gaussian Distribution", y = "Density") +
theme_minimal()
# Generate 10,000 random samples from N(0,1)
samples <- rnorm(10000, mean = 0, sd = 1)
# Plot histogram
hist(samples, breaks = 50, probability = TRUE,
col = "lightgray", border = "white",
main = "Histogram with Gaussian Curve")
# Overlay the theoretical curve
curve(dnorm(x, mean = 0, sd = 1),
col = "red", lwd = 2, add = TRUE)
library(ggplot2)
set.seed(123)
# 1. Right skewed (Exponential)
right_skew <- rexp(1000, rate = 1)
# 2. Left skewed (Negative Exponential)
left_skew <- -rexp(1000, rate = 1)
# 3. Unimodal (Normal)
unimodal <- rnorm(1000, mean = 0, sd = 1)
# 4. Bimodal (Mixture of two Normals)
bimodal <- c(rnorm(500, mean = -2, sd = 0.5),
rnorm(500, mean = 2, sd = 0.5))
# Combine into one data frame
df <- data.frame(
value = c(right_skew, left_skew, unimodal, bimodal),
type  = factor(rep(c("Right Skewed", "Left Skewed",
"Unimodal", "Bimodal"), each = 1000))
)
# Relative frequency histograms
ggplot(df, aes(x = value)) +
geom_histogram(aes(y = ..count../sum(..count..)),
bins = 30, fill = "steelblue", color = "white") +
facet_wrap(~ type, scales = "free") +
theme_minimal() +
labs(title = "Relative Frequency Histograms",
x = "Value", y = "Relative Frequency")
